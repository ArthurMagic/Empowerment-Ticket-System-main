# Database Configuration
# PostgreSQL connection string for the Neon database
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Server Configuration
PORT=8080
BASE_PATH=/
NODE_ENV=development
LOG_LEVEL=info

# API Configuration
# Resend email API key (optional)
RESEND_API_KEY=

# Security
# Admin authentication key for protected endpoints
ADMIN_KEY=empowerment-admin-2026

# Email Configuration (Gmail)
# Gmail address for sending notifications
GMAIL_USER="noreply.tickets.empowerment@gmail.com"
# Gmail app-specific password (16-digit password from Google Account)
GMAIL_PASS="xxxx xxxx xxxx xxxx"

# Vite API URL (Frontend)
# URL where the frontend should connect to the API
VITE_API_URL=http://localhost:8080
